#!/usr/bin/env python3
# -*- coding: utf-8 -*-
import argparse, sys, os, magic, mimetypes
from pathlib import Path

# Bibliotecas adicionais instaladas:
# dev-python/python-magic

# Note for developers: "RTP" means
# here: "Real-Time Protection".
    
def objecttype(data):
    if type(data) != str:
        sys.exit(64)
        print(f"What you want to scan needs to be a string, not a {type(data).__name__}.")

    elif type(data) == str:

        protocols = ["https://", "http://"]
        # Create the list using only the real block device names
        data_devices = [f"/dev/{d}" for d in os.listdir('/sys/block/') if d.startswith(('sd', 'nvme', 'vd'))]

        if data.startswith(tuple(protocols)):
            return "url"
        
        elif Path(data).is_file():
            mimetypes.init(files=[]) # Avoid using the system's MIME types database
            
            detector = magic.Magic(mime=True)
            mime_type = detector.from_file(data)
            type_of_file_object = "file:".join(mime_type.replace("/", ":"))
            if mime_type.startswith("image/"):
                return type_of_file_object
            else:
                return "file"
            
        elif Path(data).is_dir():
            return "directory"
        
        elif data in data_devices:
            return "data_device"
        
        elif (type(data) == int) and (data >= 0) and (data <= 65535):
            return "port"

        else:
            return "unknown"

def main():
    parser = argparse.ArgumentParser(description="Simplified Guard CLI Tool")
    subparsers = parser.add_subparsers(dest="command", required=True)

    parser_scan = subparsers.add_parser("scan", help="Scan a target")
    parser_scan.add_argument("target", metavar="STRING", help="Target string")
    parser_scan.add_argument("--level", type=int, required=True, help="Integer level number")

    parser_allow = subparsers.add_parser("allow", help="Allow a target")
    parser_allow.add_argument("target", metavar="STRING", help="Target string")
    parser_allow.add_argument("--level", type=int, required=True, help="Integer level number")

    parser_block = subparsers.add_parser("block", help="Block a target")
    parser_block.add_argument("target", metavar="STRING", help="Target string")
    parser_block.add_argument("--level", type=int, required=True, help="Integer level number")

    parser_rtp = subparsers.add_parser("rtp", help="Configure RTP mode")
    parser_rtp.add_argument("value", choices=["true", "false"], help="Boolean value for rtp")

    parser_firewall = subparsers.add_parser("firewall", help="Configure firewall")
    parser_firewall.add_argument("value", choices=["true", "false"], help="Boolean value for firewall")

    subparsers.add_parser("update", help="Update guard")

    if len(sys.argv) == 1:
        parser.print_help()
        sys.exit(1)

    args = parser.parse_args()

    if args.command == "scan":
        print(f"Running: guard scan {args.target} --level {args.level}")
    elif args.command == "allow":
        print(f"Running: guard allow {args.target} --level {args.level}")
    elif args.command == "block":
        print(f"Running: guard block {args.target} --level {args.level}")
    elif args.command == "rtp":
        print(f"Running: guard rtp {args.value}")
    elif args.command == "firewall":
        print(f"Running: guard firewall {args.value}")
    elif args.command == "update":
        print("Running: guard update")


if __name__ == "__main__":
    main()